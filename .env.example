# ─────────────────────────────────────────────────────────────
# 9Expert Break Screen — environment
# Copy to .env.local and fill in real values (never commit .env.local)
# ─────────────────────────────────────────────────────────────

# MSDB token-gated endpoint that returns the full { [slug]: profile } map
# (built in PROMPT 02). Read SERVER-SIDE only, during ISR resolution.
MSDB_PROFILES_URL=https://msdb.example.com/api/public/break-screen/profiles

# API key matching one of MSDB's BREAK_SCREEN_API_KEYS.
# SERVER-ONLY — do NOT prefix with NEXT_PUBLIC_. It must never reach the browser bundle.
MSDB_BREAK_SCREEN_API_KEY=replace-with-real-key
